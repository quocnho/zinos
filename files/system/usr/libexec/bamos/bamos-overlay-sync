#!/usr/bin/env bash
# BamOS Overlay Sync
# On first boot (or after reset), installs all packages listed in
# /var/lib/bamos/packages.list into the overlay.
#
# On subsequent boots, checks for state file and skips if already synced.
# Also handles updating overlay packages after a base image update.

set -euo pipefail

PACKAGES_LIST="/var/lib/bamos/packages.list"
STATE_FILE="/var/lib/bamos/overlay.state"
SYNCED_MARKER="/var/lib/bamos/overlay.synced"
OVERLAY_MOUNTED="/var/lib/bamos/overlay.dirty"

# ── Verify overlay is mounted ─────────────────────────────────────────────────
if ! mountpoint -q /usr; then
    echo "[bamos] ERROR: /usr is not mounted — overlay may not be active."
    exit 1
fi

# ── Check if this is a fresh build (state file missing) ───────────────────────
if [[ ! -f "$STATE_FILE" ]]; then
    echo "[bamos] First boot detected — performing initial package install..."

    if [[ -f "$PACKAGES_LIST" ]]; then
        PKG_COUNT=$(grep -v '^\s*#' "$PACKAGES_LIST" | grep -v '^\s*$' | wc -l)
        echo "[bamos] Installing $PKG_COUNT packages from packages.list..."

        PKGS=$(grep -v '^\s*#' "$PACKAGES_LIST" | grep -v '^\s*$' | tr '\n' ' ')
        if [[ -n "$PKGS" ]]; then
            dnf5.real install -y $PKGS 2>&1 || echo "[bamos] WARNING: Some packages failed to install"
        fi
    else
        echo "[bamos] No packages.list found — skipping initial install."
    fi
fi

# ── Check for base image update (bootc upgrade) ───────────────────────────────
# After a bootc upgrade, the overlay lower dir changes. We need to check if
# any overlay packages need updating against the new base.
if [[ -f "$SYNCED_MARKER" ]]; then
    echo "[bamos] Checking for overlay package updates..."
    dnf5.real distro-sync -y --releasever "$(rpm -E %fedora)" 2>&1 || true
fi

# ── Mark synced ───────────────────────────────────────────────────────────────
touch "$SYNCED_MARKER"
echo "[bamos] Overlay sync complete."
