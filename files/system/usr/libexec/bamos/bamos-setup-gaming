#!/usr/bin/env bash
# BamOS Gaming Setup — based on Bazzite gaming configuration philosophy
# Installs gaming packages into the persistent overlay.
# Usage: sudo bamos setup-gaming
#
# Gaming philosophy:
#   - Steam via RPM for native performance (not Flatpak)
#   - Gamescope for Wayland gaming isolation
#   - MangoHud + vkBasalt pre-configured
#   - GameMode + ananicy + BORE for CPU/IO priority
#   - Bluetooth controller fixes (UserspaceHID)
#   - Input remapper for custom controller bindings

set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║     BamOS Gaming Setup              ║"
echo "╚══════════════════════════════════════╝"
echo ""

# ── Check overlay is active ───────────────────────────────────────────────────
if ! mountpoint -q /usr; then
    echo "ERROR: Persistent overlay not mounted on /usr."
    echo "Run 'sudo bamos setup-overlay' first or reboot."
    exit 1
fi

# ── Step 1: Core gaming RPMs ─────────────────────────────────────────────────
echo ""
echo "▶ Step 1/5: Installing core gaming packages..."
dnf5.real install -y \
    steam \
    lutris \
    mangohud mangohud.i686 \
    vkBasalt vkBasalt.i686 \
    goverlay \
    protontricks \
    steam-devices \
    gamemode gamemode.i686 \
    gamescope \
    gamescope-libs gamescope-libs.i686 \
    input-remapper \
    vulkan-tools \
    vulkan-low-latency-layer \
    2>&1 || {
        echo "Some packages unavailable. Installing core gaming essentials..."
        dnf5.real install -y \
            steam mangohud mangohud.i686 \
            gamemode gamemode.i686 \
            steam-devices gamescope 2>&1 || true
    }

# ── Step 2: Gaming Flatpaks ──────────────────────────────────────────────────
echo ""
echo "▶ Step 2/5: Installing gaming Flatpaks..."
flatpak install -y --noninteractive flathub \
    net.lutris.Lutris \
    com.heroicgameslauncher.hgl \
    com.discordapp.Discord \
    org.prismlauncher.PrismLauncher \
    2>/dev/null || true

# ── Step 3: GameMode configuration ───────────────────────────────────────────
echo ""
echo "▶ Step 3/5: Configuring GameMode..."
mkdir -p /etc/gamemode
if [[ ! -f /etc/gamemode/gamemode.ini ]]; then
    cat > /etc/gamemode/gamemode.ini << 'EOF'
[general]
renice=10
softrealtime=auto
releasemem=enable
desiredgov=performance
ioprio=0
inhibit-screensaver=auto
[cpu]
gov=performance
energy_performance_preference=performance
[gpu]
apply_gpu_optimisations=accept-responsibility
amd_performance_level=high
nvidia_powermizer_level=1
EOF
fi
systemctl enable gamemoded 2>/dev/null || true

# ── Step 4: Bluetooth controller fixes ───────────────────────────────────────
echo ""
echo "▶ Step 4/5: Configuring Bluetooth for gaming controllers..."
# UserspaceHID ensures Xbox/PS/Switch Pro controllers work via Bluetooth
if grep -q "^#UserspaceHID" /etc/bluetooth/input.conf 2>/dev/null; then
    sed -i 's/#UserspaceHID.*/UserspaceHID=true/' /etc/bluetooth/input.conf
elif ! grep -q "^UserspaceHID" /etc/bluetooth/input.conf 2>/dev/null; then
    echo "UserspaceHID=true" >> /etc/bluetooth/input.conf
fi

# Enable input-remapper for custom controller bindings
systemctl enable input-remapper 2>/dev/null || true

# ── Step 5: Install Winetricks (from upstream) ───────────────────────────────
echo ""
echo "▶ Step 5/5: Installing Winetricks..."
if command -v curl &>/dev/null; then
    curl -fsSL "https://raw.githubusercontent.com/Winetricks/winetricks/master/src/winetricks" \
        -o /usr/bin/winetricks 2>/dev/null && \
    chmod +x /usr/bin/winetricks && \
    echo "Winetricks installed." || echo "Winetricks download failed (non-critical)."
fi

echo ""
echo "✅ Gaming setup complete!"
echo ""
echo "🎮 Installed:"
echo "   Steam, Lutris, MangoHud, GameMode, Gamescope"
echo "   vkBasalt, Protontricks, Input-Remapper"
echo ""
echo "📊 Key shortcuts:"
echo "   Shift+F12  — Toggle MangoHud overlay"
echo "   Home       — Toggle vkBasalt (sharpening)"
echo ""
echo "🎯 Launch Steam with Gamescope:"
echo "   gamescope -- steam"
echo ""
echo "📦 Gaming Flatpaks available:"
echo "   Lutris, Heroic Games Launcher, Discord, Prism Launcher"
