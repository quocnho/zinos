#!/usr/bin/env bash
# BamOS Gaming Setup
# Installs gaming packages into the overlay.
# Usage: sudo bamos setup-gaming
#
# IMPORTANT: This script runs on the INSTALLED SYSTEM (not during container build).
# It installs packages into the persistent overlay on /usr.

set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║     BamOS Gaming Setup              ║"
echo "╚══════════════════════════════════════╝"
echo ""

# ── Check overlay is active ───────────────────────────────────────────────────
if ! mountpoint -q /usr; then
    echo "ERROR: Persistent overlay not mounted on /usr."
    echo "Run 'sudo bamos setup-overlay' first or reboot."
    exit 1
fi

# ── Install gaming RPMs ───────────────────────────────────────────────────────
echo "▶ Installing gaming packages..."
dnf5.real install -y \
    steam \
    lutris \
    mangohud mangohud.i686 \
    vkBasalt vkBasalt.i686 \
    goverlay \
    protontricks \
    steam-devices \
    gamemode gamemode.i686 \
    2>&1 || {
        echo "Some packages failed. Continuing with core gaming packages..."
        dnf5.real install -y steam mangohud mangohud.i686 gamemode gamemode.i686 steam-devices 2>&1 || true
    }

# ── Install gaming Flatpaks ───────────────────────────────────────────────────
echo "▶ Installing gaming Flatpaks..."
flatpak install -y --noninteractive flathub \
    net.lutris.Lutris \
    com.heroicgameslauncher.hgl \
    com.discordapp.Discord \
    org.prismlauncher.PrismLauncher \
    2>/dev/null || true

# ── Configure gamemode ─────────────────────────────────────────────────────────
echo "▶ Configuring gamemode..."
mkdir -p /etc/gamemode
cat > /etc/gamemode/gamemode.ini << 'EOF'
[general]
renice=10
softrealtime=auto
releasemem=enable
desiredgov=performance
EOF

# ── Enable gamemoded service ──────────────────────────────────────────────────
systemctl enable gamemoded 2>/dev/null || true

echo ""
echo "✅ Gaming setup complete!"
echo ""
echo "Installed: steam, lutris, mangohud, gamemode, vkBasalt, protontricks"
echo "Flatpaks:  Lutris, Heroic Games Launcher, Discord, Prism Launcher"
echo ""
echo "  🎮 Run 'steam' to get started!"
echo "  📊 Press Shift+F12 to toggle MangoHud in-game"
