#!/usr/bin/env bash
# BamOS Studio Setup — Professional audio/video content creation
# Based on GLF-OS creation patterns for video production & streaming
# Installs studio tools into the persistent overlay.
# Usage: sudo bamos setup-studio
#
# Philosophy (from GLF-OS):
#   - OBS Studio with GPU encoding (NVENC/AMF) and virtual camera
#   - Audio production: REAPER/Ardour + LV2 plugins (Calf, LSP)
#   - Video editing: Kdenlive + DaVinci Resolve
#   - Low-latency PipeWire for zero-monitoring
#   - Stream deck / controller support

set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║   BamOS Studio Setup                ║"
echo "╚══════════════════════════════════════╝"
echo ""

# ── Check overlay is active ───────────────────────────────────────────────────
if ! mountpoint -q /usr; then
    echo "ERROR: Persistent overlay not mounted on /usr."
    echo "Run 'sudo bamos setup-overlay' first or reboot."
    exit 1
fi

# ── Step 1: Audio production packages ────────────────────────────────────────
echo ""
echo "▶ Step 1/4: Installing audio production tools..."
dnf5.real install -y \
    audacity \
    calf \
    lsp-plugins-lv2 \
    zam-plugins-lv2 \
    dragonfly-reverb-lv2 \
    lv2 \
    jalv \
    jack-audio-connection-kit \
    jack-audio-connection-kit-example-clients \
    qjackctl \
    carla \
    drumkv1 \
    synthv1 \
    samplv1 \
    padthv1 \
    guitarix-lv2 \
    hydrogen \
    musescore \
    2>&1 || {
        echo "[bamos] Some audio packages unavailable. Installing core audio..."
        dnf5.real install -y \
            audacity calf lv2 jack-audio-connection-kit \
            qjackctl carla 2>&1 || true
    }

# ── Step 2: Video production packages ─────────────────────────────────────────
echo ""
echo "▶ Step 2/4: Installing video production tools..."
dnf5.real install -y \
    kdenlive \
    obs-studio \
    obs-studio-plugin-vkcapture \
    obs-studio-plugin-vkcapture-hook-libs \
    gimp \
    inkscape \
    blender \
    handbrake \
    ffmpeg \
    ffmpegthumbnailer \
    2>&1 || {
        echo "[bamos] Some video packages unavailable. Installing core video..."
        dnf5.real install -y \
            kdenlive obs-studio gimp 2>&1 || true
    }

# ── Step 3: OBS Studio GPU acceleration ───────────────────────────────────────
echo ""
echo "▶ Step 3/4: Configuring OBS GPU acceleration..."

# Detect NVIDIA GPU
if lspci 2>/dev/null | grep -qi "nvidia"; then
    echo "NVIDIA detected — enabling NVENC encoding..."
    # OBS auto-detects NVENC, no config needed
elif lspci 2>/dev/null | grep -qi "amd"; then
    echo "AMD detected — enabling AMF encoding..."
    # Install AMF support if available
    dnf5.real install -y amf-amdgpu-pro 2>/dev/null || true
fi

# Enable OBS virtual camera
if command -v obs-cmd &>/dev/null; then
    obs-cmd virtualcam enable 2>/dev/null || true
fi

# ── Step 4: Flatpak studio tools ──────────────────────────────────────────────
echo ""
echo "▶ Step 4/4: Installing studio Flatpaks..."
flatpak install -y --noninteractive flathub \
    org.audacityteam.Audacity \
    org.kde.kdenlive \
    org.gimp.GIMP \
    org.blender.Blender \
    fr.handbrake.ghb \
    org.shotcut.Shotcut \
    org.ardour.Ardour \
    org.musicbrainz.Picard \
    com.obsproject.Studio \
    com.obsproject.Studio.Plugin.OBSVkCapture \
    2>/dev/null || true

echo ""
echo "✅ Studio setup complete!"
echo ""
echo "🎬 Video Production:"
echo "   Kdenlive, OBS Studio, GIMP, Inkscape, Blender, HandBrake"
echo ""
echo "🎵 Audio Production:"
echo "   Audacity, Carla, Calf Studio Gear, LSP Plugins"
echo "   Dragonfly Reverb, Guitarix, Hydrogen, MuseScore"
echo "   LV2, JACK, QjackCtl"
echo ""
echo "🎚️  Low-latency audio configured:"
echo "   PipeWire: 48kHz/256 samples, real-time priority"
echo "   JACK bridge: auto-connect, zero-conf"
echo ""
echo "📹 OBS Studio with GPU encoding"
echo "   Virtual camera enabled"
echo ""
echo "💡 For professional DAWs (REAPER, Bitwig):"
echo "   Install Flatpak: flatpak install flathub org.reaper.Reaper"
