#!/usr/bin/env bash
# BamOS System Status
# Shows system information including overlay status, kernel, bootc deployment.
#
# Usage: bamos status

set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║     BamOS System Status              ║"
echo "╚══════════════════════════════════════╝"

# ── OS Info ──────────────────────────────────────────────────────────────────
echo ""
echo "▶ OS:"
cat /etc/os-release 2>/dev/null | head -7 | sed 's/^/  /'

# ── Kernel ───────────────────────────────────────────────────────────────────
echo ""
echo "▶ Kernel:"
uname -r | sed 's/^/  /'

# ── Overlay Status ────────────────────────────────────────────────────────────
echo ""
echo "▶ Overlay:"
if mountpoint -q /usr; then
    if grep -q "overlay" /proc/mounts | grep -q " /usr "; then
        echo "  ✅ Persistent overlay ACTIVE on /usr"
        DF_OUTPUT=$(df -h /usr 2>/dev/null | tail -1)
        echo "  Usage: $(echo "$DF_OUTPUT" | awk '{print $3}') / $(echo "$DF_OUTPUT" | awk '{print $2}')"
    else
        echo "  ⚠️  /usr mounted but not as overlay"
    fi
else
    echo "  ❌ Overlay NOT mounted — run 'sudo bamos setup-overlay' or reboot"
fi

# Check state file
STATE_FILE="/var/lib/bamos/overlay.state"
if [[ -f "$STATE_FILE" ]]; then
    echo "  State: $(cat "$STATE_FILE")"
else
    echo "  State: fresh (first boot pending)"
fi

# ── Bootc Status ──────────────────────────────────────────────────────────────
echo ""
echo "▶ Bootc:"
bootc status 2>/dev/null | head -10 | sed 's/^/  /' || echo "  (bootc not available)"

# ── Package Count ──────────────────────────────────────────────────────────────
PACKAGES_LIST="/var/lib/bamos/packages.list"
if [[ -f "$PACKAGES_LIST" ]]; then
    COUNT=$(grep -v '^\s*#' "$PACKAGES_LIST" | grep -v '^\s*$' | wc -l)
    echo ""
    echo "▶ Overlay packages: $COUNT"
fi

echo ""
