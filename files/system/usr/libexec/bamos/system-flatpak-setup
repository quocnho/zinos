#!/usr/bin/env bash
# BamOS System Flatpak Setup
# Installs predefined system-wide Flatpaks from a list file.
# The list file is at /usr/share/bamos/flatpaks.list
# and can be overridden at /etc/bamos/flatpaks.list

set -euo pipefail

# Check multiple locations for flatpak list
for LIST in "/etc/bamos/flatpaks.list" "/usr/share/bamos/flatpaks.list"; do
    if [[ -f "$LIST" ]]; then
        FLATPAK_LIST="$LIST"
        break
    fi
done

if [[ -z "${FLATPAK_LIST:-}" ]]; then
    echo "[bamos] No flatpaks.list found — skipping."
    exit 0
fi

echo "[bamos] Installing system Flatpaks from $FLATPAK_LIST..."

while IFS= read -r app || [[ -n "$app" ]]; do
    [[ "$app" =~ ^#.*$ || -z "$app" ]] && continue

    if flatpak info "$app" &>/dev/null; then
        echo "[bamos] Flatpak already installed: $app"
    else
        echo "[bamos] Installing Flatpak: $app..."
        flatpak install -y --noninteractive flathub "$app" 2>&1 || echo "[bamos] WARNING: Failed to install $app"
    fi
done < "$FLATPAK_LIST"

echo "[bamos] Flatpak setup complete."
