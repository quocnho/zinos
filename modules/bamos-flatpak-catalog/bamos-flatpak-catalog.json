{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BamOS Flatpak Catalog",
  "description": "Installs and configures the Bazaar Flatpak manager with BamOS catalog",
  "type": "object",
  "properties": {
    "install": {
      "type": "boolean",
      "description": "Install bazaar package from COPR",
      "default": true
    },
    "catalog": {
      "type": "string",
      "description": "Path to custom catalog YAML",
      "default": "/usr/share/bamos/bazaar/content.yaml"
    }
  },
  "additionalProperties": false
}
